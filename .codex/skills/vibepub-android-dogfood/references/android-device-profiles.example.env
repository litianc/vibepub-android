# Copy this file to secrets/android-device-profiles.env.
# The secrets/ directory is git-ignored, so local WiFi/IP details stay private.

# Profile names are normalized to uppercase and dashes become underscores.
# Example invocation:
# .codex/skills/vibepub-android-dogfood/scripts/run-device-dogfood.sh --profile redmi-home --mode install

VIBEPUB_DEVICE_REDMI_HOME_SERIAL="192.168.1.42:43201"
VIBEPUB_DEVICE_REDMI_HOME_CONNECT_TARGETS="192.168.1.42:43201"

# If wireless debugging ports change often on the same WiFi, keep older and
# newer candidates here. The script selects the first currently connected one.
VIBEPUB_DEVICE_REDMI_HOME_SERIALS="192.168.1.42:43201 192.168.1.42:42327"

VIBEPUB_DEVICE_REDMI_OFFICE_SERIAL="10.0.8.42:43355"
VIBEPUB_DEVICE_REDMI_OFFICE_CONNECT_TARGETS="10.0.8.42:43355"

# USB serials can also be recorded. Leave CONNECT_TARGETS empty for USB.
VIBEPUB_DEVICE_REDMI_USB_SERIAL="AUVWCYNROZPNFUDI"
VIBEPUB_DEVICE_REDMI_USB_CONNECT_TARGETS=""
